# API Configuration
# Set to 'false' to connect to the real API Gateway
EXPO_PUBLIC_USE_MOCK_API=false

# API Gateway URL
EXPO_PUBLIC_API_BASE_URL=https://identio-api-gateway-production.up.railway.app

# For production or deployed API Gateway, use the actual URL:
# EXPO_PUBLIC_API_BASE_URL=https://your-api-gateway.com
